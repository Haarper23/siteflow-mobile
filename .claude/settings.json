{
  "enabledPlugins": {
    "expo@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.development.local)",
      "Read(./.env.production)",
      "Read(./.env.production.local)",
      "Read(./.env.staging)",
      "Read(./.env.staging.local)",
      "Read(./.env.test)",
      "Read(./.env.test.local)",
      "Read(./**/.env)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p8)",
      "Read(./**/*.jks)",
      "Read(./**/*.mobileprovision)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(eas build:*)",
      "Bash(eas submit:*)",
      "Bash(eas deploy:*)",
      "Bash(expo publish:*)"
    ]
  }
}
