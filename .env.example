# =============================================================================
# SiteFlow AI — Environment Template
# =============================================================================
# Copy this file to `.env` for local use. `.env` is gitignored; this template
# (`.env.example`) is committed and must contain PLACEHOLDERS ONLY — never real
# values.
#
# Every variable here is OPTIONAL. With none of them set the app runs locally
# with monitoring DISABLED and the environment inferred from the build mode.
# =============================================================================

# -----------------------------------------------------------------------------
# EXPO_PUBLIC_* variables are NOT secret.
# -----------------------------------------------------------------------------
# Anything prefixed with EXPO_PUBLIC_ is embedded into the app bundle at build
# time and is fully visible to every user who downloads the app. Use it ONLY for
# non-secret config such as public URLs, feature flags, the deployment
# environment name, or a publishable client key. Never put a private key, token,
# password, or credential here.

# Deployment environment the running app reports as. One of:
#   development | preview | production
# When unset, the app falls back to "development" in dev builds and "production"
# in release builds. EAS build profiles set this per profile (see eas.json).
EXPO_PUBLIC_APP_ENV=

# Sentry DSN — a PUBLISHABLE client key (not a secret), safe to ship in the
# bundle. Leave EMPTY to keep crash/error monitoring fully disabled (the default
# for local dev, CI, and tests). Set it to enable monitoring.
# Use only a synthetic placeholder here, e.g. https://public@example.invalid/1
EXPO_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# BUILD-ONLY secrets — used by tooling during native/EAS builds, NEVER shipped.
# -----------------------------------------------------------------------------
# These configure Sentry source-map upload during a legitimate native/EAS build.
# They are NOT runtime app config and MUST NOT be prefixed with EXPO_PUBLIC_
# (that would embed them in the public bundle). Do not commit real values.
#
# Store them as secure EAS environment variables / CI secrets — never in this
# file with real values, never in app.json, never in source. In particular,
# SENTRY_AUTH_TOKEN is a real credential: keep it out of the bundle and out of
# Git entirely. See docs/monitoring/sentry-setup.md.
#
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_AUTH_TOKEN=set-only-as-a-secure-build-secret

# -----------------------------------------------------------------------------
# Private service keys belong to the FUTURE BACKEND — never the mobile app.
# -----------------------------------------------------------------------------
# The mobile client must never hold any of the following. They live only in the
# backend's own server-side environment, which the app talks to over HTTPS:
#
#   - AI provider API keys (Anthropic, OpenAI, etc.)
#   - Database connection strings and credentials
#   - JWT signing secrets
#   - Any third-party private/secret key
#
# Do NOT add these to this mobile project's environment under any prefix.
# See `.claude/rules/security.md` for the full policy.
